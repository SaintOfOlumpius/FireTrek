# ---------------------------------------------------------------------------
# FireTrek environment variables
# Copy to .env and fill in real values. Never commit .env to version control.
# ---------------------------------------------------------------------------

# Django
SECRET_KEY=your-secret-key-here-use-django-get-random-secret-key
DEBUG=False
ALLOWED_HOSTS=api.firetrek.io,localhost
DJANGO_SETTINGS_MODULE=config.settings.production

# Database
DATABASE_URL=postgis://user:password@localhost:5432/firetrek

# Redis
REDIS_URL=redis://localhost:6379

# CORS
CORS_ALLOWED_ORIGINS=https://app.firetrek.io

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@firetrek.io

# AWS S3 (media and firmware files)
AWS_STORAGE_BUCKET_NAME=firetrek-media
AWS_S3_REGION_NAME=us-east-1

# Sentry
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
