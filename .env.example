SECRET_KEY=your-secret-key-here-use-django-get-random-secret-key
DEBUG=False
ALLOWED_HOSTS=api.firetrek.io,localhost
DJANGO_SETTINGS_MODULE=config.settings.production

# Database
DATABASE_URL=postgis://user:password@localhost:5432/firetrek

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=https://app.firetrek.io

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@firetrek.io

# AWS S3
AWS_STORAGE_BUCKET_NAME=firetrek-media
AWS_S3_REGION_NAME=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id         # <-- missing
AWS_SECRET_ACCESS_KEY=your-secret-access-key  # <-- missing

# Sentry
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# Celery (if using separate broker config)
CELERY_BROKER_URL=redis://localhost:6379/0

# JWT (if configuring expiry via env)
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7